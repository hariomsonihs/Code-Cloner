# ========================================
# ENVIRONMENT VARIABLES - EXAMPLE FILE
# ========================================
# 
# ⚠️ IMPORTANT: Ye sirf example file hai!
# 
# Setup Instructions:
# 1. Is file ko copy karo aur naam rakho: .env
# 2. Apne actual Firebase credentials daalo
# 3. .env file ko KABHI GitHub par push mat karo
# 
# ========================================

# Firebase Configuration
FIREBASE_API_KEY=your_api_key_here
FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id
FIREBASE_MEASUREMENT_ID=your_measurement_id

# Firebase Cloud Messaging (Push Notifications)
FIREBASE_VAPID_KEY=your_vapid_key_here

# ========================================
# NOTES:
# ========================================
# 
# Firebase Console se credentials kaise nikaalein:
# 1. https://console.firebase.google.com/
# 2. Project Settings > General > Your apps
# 3. Web app select karo
# 4. Config copy karo
# 
# VAPID Key kaise nikaalein:
# 1. Project Settings > Cloud Messaging
# 2. Web Push certificates section
# 3. Generate key pair (agar nahi hai)
# 4. Key pair copy karo
# 
# ========================================
