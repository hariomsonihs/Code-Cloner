rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ── Public read access for all content collections ──
    match /{collection}/{document} {
      allow read: if collection in ['articles', 'tips', 'facts', 'projects', 'resources'];
    }
    
    // ── Allow public write for reactions and views ONLY ──
    match /articles/{articleId} {
      allow read: if true;
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions', 'views']);
      allow write: if request.auth != null; // Admin only for create/delete
    }
    
    match /tips/{tipId} {
      allow read: if true;
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions', 'views']);
      allow write: if request.auth != null;
    }
    
    match /facts/{factId} {
      allow read: if true;
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions', 'views']);
      allow write: if request.auth != null;
    }
    
    match /projects/{projectId} {
      allow read: if true;
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions', 'views']);
      allow write: if request.auth != null;
    }
    
    match /resources/{resourceId} {
      allow read: if true;
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions', 'views']);
      allow write: if request.auth != null;
    }
    
    // ── Allow public read/write for comments (subcollection) ──
    match /articles/{articleId}/comments/{commentId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['name', 'text', 'createdAt']) 
                    && request.resource.data.text is string 
                    && request.resource.data.text.size() > 0 
                    && request.resource.data.text.size() <= 1000;
      allow delete: if request.auth != null;
    }
    
    match /tips/{tipId}/comments/{commentId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['name', 'text', 'createdAt']) 
                    && request.resource.data.text is string 
                    && request.resource.data.text.size() > 0 
                    && request.resource.data.text.size() <= 1000;
      allow delete: if request.auth != null;
    }
    
    match /facts/{factId}/comments/{commentId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['name', 'text', 'createdAt']) 
                    && request.resource.data.text is string 
                    && request.resource.data.text.size() > 0 
                    && request.resource.data.text.size() <= 1000;
      allow delete: if request.auth != null;
    }
    
    match /projects/{projectId}/comments/{commentId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['name', 'text', 'createdAt']) 
                    && request.resource.data.text is string 
                    && request.resource.data.text.size() > 0 
                    && request.resource.data.text.size() <= 1000;
      allow delete: if request.auth != null;
    }
    
    match /resources/{resourceId}/comments/{commentId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['name', 'text', 'createdAt']) 
                    && request.resource.data.text is string 
                    && request.resource.data.text.size() > 0 
                    && request.resource.data.text.size() <= 1000;
      allow delete: if request.auth != null;
    }
    
    // ── Notifications (public read, admin write) ──
    match /notifications/{notifId} {
      allow read: if true;
      allow write, delete: if request.auth != null; // Admin only
    }
    
    // ── FCM Tokens for push notifications ──
    match /fcm_tokens/{token} {
      allow read, write: if true;
    }
    
    // ── Media Library (admin only) ──
    match /media/{mediaId} {
      allow read: if true; // Anyone can read media URLs
      allow write, delete: if request.auth != null; // Only admin can add/delete
    }
    
    // ── Users collection (admin full access, users own data only) ──
    match /users/{userId} {
      allow read: if request.auth != null; // Admin can read all users
      allow write: if request.auth != null && request.auth.uid == userId; // Users can only write their own
      allow update, delete: if request.auth != null; // Admin can update/delete any user
      
      // User history subcollection
      match /history/{historyId} {
        allow read, write: if request.auth != null; // Admin can read/write all history
        allow delete: if request.auth != null; // Admin can delete history
      }
    }
    
    // ── Default deny all other paths ──
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
