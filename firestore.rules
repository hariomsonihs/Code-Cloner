rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ── Helper function to check if user is admin ──
    function isAdmin() {
      return request.auth != null && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }
    
    // ── Public read access for all content collections ──
    match /{collection}/{document} {
      allow read: if collection in ['articles', 'tips', 'facts', 'projects', 'resources'];
    }
    
    // ── Allow public write for reactions and views ONLY ──
    match /articles/{articleId} {
      allow read: if true;
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions', 'views']);
      allow write: if isAdmin(); // Admin only for create/delete
    }
    
    match /tips/{tipId} {
      allow read: if true;
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions', 'views']);
      allow write: if isAdmin();
    }
    
    match /facts/{factId} {
      allow read: if true;
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions', 'views']);
      allow write: if isAdmin();
    }
    
    match /projects/{projectId} {
      allow read: if true;
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions', 'views']);
      allow write: if isAdmin();
    }
    
    match /resources/{resourceId} {
      allow read: if true;
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions', 'views']);
      allow write: if isAdmin();
    }
    
    // ── Allow public read/write for comments (subcollection) ──
    match /articles/{articleId}/comments/{commentId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['name', 'text', 'createdAt']) 
                    && request.resource.data.text is string 
                    && request.resource.data.text.size() > 0 
                    && request.resource.data.text.size() <= 1000;
      allow delete: if isAdmin();
    }
    
    match /tips/{tipId}/comments/{commentId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['name', 'text', 'createdAt']) 
                    && request.resource.data.text is string 
                    && request.resource.data.text.size() > 0 
                    && request.resource.data.text.size() <= 1000;
      allow delete: if isAdmin();
    }
    
    match /facts/{factId}/comments/{commentId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['name', 'text', 'createdAt']) 
                    && request.resource.data.text is string 
                    && request.resource.data.text.size() > 0 
                    && request.resource.data.text.size() <= 1000;
      allow delete: if isAdmin();
    }
    
    match /projects/{projectId}/comments/{commentId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['name', 'text', 'createdAt']) 
                    && request.resource.data.text is string 
                    && request.resource.data.text.size() > 0 
                    && request.resource.data.text.size() <= 1000;
      allow delete: if isAdmin();
    }
    
    match /resources/{resourceId}/comments/{commentId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['name', 'text', 'createdAt']) 
                    && request.resource.data.text is string 
                    && request.resource.data.text.size() > 0 
                    && request.resource.data.text.size() <= 1000;
      allow delete: if isAdmin();
    }
    
    // ── Notifications (public read, admin write) ──
    match /notifications/{notifId} {
      allow read: if true;
      allow write, delete: if isAdmin();
    }
    
    // ── FCM Tokens for push notifications ──
    match /fcm_tokens/{token} {
      allow read, write: if true;
    }
    
    // ── Media Library (admin only) ──
    match /media/{mediaId} {
      allow read: if true;
      allow write, delete: if isAdmin();
    }
    
    // ── Users collection ──
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && 
                      (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
      
      match /history/{historyId} {
        allow read, write: if request.auth != null && 
                             (request.auth.uid == userId || isAdmin());
        allow delete: if isAdmin();
      }
    }
    
    // ── Default deny all other paths ──
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
